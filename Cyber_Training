<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>April Fools Prank</title>
    <style>
        body { 
            display: flex; 
            justify-content: center; 
            align-items: center; 
            height: 100vh; 
            background-color: #f0f0f0; 
            font-family: Arial, sans-serif; 
        }
        .message {
            text-align: center;
            padding: 20px;
            border: 2px solid #008CBA;
            border-radius: 15px;
            background-color: #white;
        }
    </style>
    <script>
        function showMessage() {
            alert('Happy April Fool! 🎉 But remember to never click on suspicious links! ⚠️');
        }
    </script>
</head>
<body>
    <div class="message">
        <h1>Click the button below for a surprise!</h1>
        <button onclick="showMessage()">Click Me!</button>
    </div>
</body>
</html>
